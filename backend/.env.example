# ===========================================
# BUZZ-ROOT Backend — Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# For cloud deployment (Render, Railway, etc.), set these
# as environment variables in the service dashboard.

# --- Database ---
DATABASE_URL=sqlite:///./cpsm.db
# For production (PostgreSQL):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- URLs ---
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# --- Demo Data ---
# Set to "true" to seed demo data on startup (development only)
SEED_DEMO=true

# --- YouTube Data API ---
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# --- TikTok API ---
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# --- Meta Graph API (Instagram) ---
META_APP_ID=
META_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=
